{
  "name": "@agentspan-ai/sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for building and running AI agents on Agentspan",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "workspaces": [
    "examples"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "require": "./dist/testing/index.cjs"
    },
    "./vercel-ai": {
      "types": "./dist/wrappers/ai.d.ts",
      "import": "./dist/wrappers/ai.js",
      "require": "./dist/wrappers/ai.cjs"
    },
    "./langgraph": {
      "types": "./dist/wrappers/langgraph.d.ts",
      "import": "./dist/wrappers/langgraph.js",
      "require": "./dist/wrappers/langgraph.cjs"
    },
    "./langchain": {
      "types": "./dist/wrappers/langchain.d.ts",
      "import": "./dist/wrappers/langchain.js",
      "require": "./dist/wrappers/langchain.cjs"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@io-orkes/conductor-javascript": "^3.0.3",
    "dotenv": "^16.0.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.2.0",
    "@langchain/langgraph": ">=0.2.0",
    "ai": ">=3.0.0",
    "zod": "^3.22.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    },
    "zod-to-json-schema": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "@langchain/core": {
      "optional": true
    },
    "@langchain/langgraph": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.0.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^2.1.9",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.23.5"
  },
  "scripts": {
    "build": "tsup && npm run verify:dist",
    "verify:dist": "node ./scripts/verify-dist.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "ws": "^8.21.0",
    "@langchain/langgraph": {
      "uuid": "^11.1.1"
    },
    "@langchain/langgraph-checkpoint": {
      "uuid": "^11.1.1"
    }
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
